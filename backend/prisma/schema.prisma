datasource db {
  provider = "sqlite"
  url      = "file:../data/database.db"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id         String   @id @default(uuid())
  phone      String   @unique
  name       String?
  proxy      String?
  status     String   @default("DISCONNECTED") // "DISCONNECTED", "CONNECTING", "CONNECTED", "BANNED"
  todaySent  Int      @default(0)
  dailyLimit Int      @default(0)
  totalSent  Int      @default(0)
  createdAt  DateTime @default(now())
}

model ContactGroup {
  id        String     @id @default(uuid())
  name      String
  subGroups SubGroup[]
  createdAt DateTime   @default(now())
}

model SubGroup {
  id        String       @id @default(uuid())
  name      String
  groupId   String
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  createdAt DateTime     @default(now())
}

model Contact {
  id             String              @id @default(uuid())
  name           String?
  phone          String
  variables      String              @default("{}") // JSON string of variables
  whatsappStatus String              @default("unknown") // "unknown", "checking", "exists", "not_found"
  subGroupId     String
  subGroup       SubGroup            @relation(fields: [subGroupId], references: [id], onDelete: Cascade)
  campaigns      CampaignRecipient[]
  createdAt      DateTime            @default(now())
}

model Template {
  id        String   @id @default(uuid())
  name      String
  body      String
  variables String   @default("[]") // JSON array of string variable names
  createdAt DateTime @default(now())
}

model Campaign {
  id             String              @id @default(uuid())
  name           String
  phones         String              @default("[]") // JSON array of sender phone numbers
  message        String
  groupName      String              // The name of the subgroup target
  groupId        String              // The ID of the subgroup target
  nextAction     DateTime?
  nextActionTime String              @default("08:00")
  minInterval    Int                 @default(600)
  maxInterval    Int                 @default(1200)
  sendFrom       String              @default("08:00")
  sendTo         String              @default("20:00")
  sent           Int                 @default(0)
  pending        Int                 @default(0)
  failed         Int                 @default(0)
  isPaused       Boolean             @default(true)
  status         String              @default("DRAFT") // "DRAFT", "SCHEDULED", "RUNNING", "PAUSED", "COMPLETED"
  recipients     CampaignRecipient[]
  createdAt      DateTime            @default(now())
}

model CampaignRecipient {
  id         String    @id @default(uuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status     String    @default("PENDING") // "PENDING", "SENT", "FAILED"
  sentAt     DateTime?
  error      String?

  @@unique([campaignId, contactId])
}
